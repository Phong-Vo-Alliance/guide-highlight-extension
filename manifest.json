{
  "manifest_version": 3,
  "name": "StepShot",
  "version": "6.4.0",
  "description": "Screenshot annotation tool for creating step-by-step guide images. Crop, badge, highlight, export.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "downloads",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "StepShot"
  },
  "commands": {
    "start-capture": {
      "suggested_key": {
        "default": "Alt+Shift+H"
      },
      "description": "Start guide capture"
    }
  }
}