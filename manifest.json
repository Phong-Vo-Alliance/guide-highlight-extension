{
  "manifest_version": 3,
  "name": "Guide Highlight Tool",
  "version": "6.3.1",
  "description": "Fixed full version: crop first, badges second, no effects until badge exists, batch export, naming, drag/resize.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "downloads",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Guide Highlight Tool"
  },
  "commands": {
    "start-capture": {
      "suggested_key": {
        "default": "Alt+Shift+H"
      },
      "description": "Start guide capture"
    }
  }
}